#include<iostream>
using namespace std;
int main(){

    int marks;
    cout<<"Tell me your Obtained Marks : "<<endl;
    cin>>marks;

    if(marks>=90){

        cout<<"GRADE A"<<endl;
    }
    else if((marks>=75) && (marks<=89)){
        cout<<"GRADE B"<<endl;
    }
    else if ((marks>=60) && (marks<=74)){
        cout<<"GRADE C"<<endl;
    }
    else{
        cout<<"FAIL"<<endl;
    }

    return 0;


}
